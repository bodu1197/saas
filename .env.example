# ============================================================
# .env.example
# ------------------------------------------------------------
# 이 파일은 git에 커밋된다. 실제 값은 절대 적지 않는다.
# 변수명은 docs/infrastructure.md에 정의되어 있으며,
# AI는 이 이름을 임의로 바꿀 수 없다.
# ============================================================

# Supabase (클라이언트 노출 가능)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (서버 전용 - 절대 NEXT_PUBLIC_ 붙이지 말 것)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase 로컬 마이그레이션용 (선택)
SUPABASE_DB_PASSWORD=

# 로컬 셸 환경 변수로 두는 것을 권장 (이 파일에는 비워둘 것)
# SUPABASE_ACCESS_TOKEN=
